# YOLO (bypass permissions / sandbox) defaults to on. Set to 0 to disable.
AI_SESSIONS_YOLO=1

# Persistent data directory. Defaults to the current working directory.
# In Docker, mount a volume here.
AI_SESSIONS_DATA_DIR=/app/data

# Default workspace (cwd) for channel-driven runs.
# If AI_SESSIONS_WORKSPACE_DIR is set, it's used verbatim.
# Otherwise, the workspace is <dataDir>/<AI_SESSIONS_WORKSPACE_NAME>; the
# folder name defaults to "workspaces".
# AI_SESSIONS_WORKSPACE_DIR=
# AI_SESSIONS_WORKSPACE_NAME=workspaces

# HTTP API port (used by `serve`).
AI_SESSIONS_PORT=7878

# Default AI agent for one-off internal tasks (auto-naming, summarization).
# AI_SESSIONS_DEFAULT_AGENT=claude

# Per-provider token budgets used by `sessions fork` to decide replay vs summary.
# AI_SESSIONS_TOKEN_BUDGET_CLAUDE=1000000
# AI_SESSIONS_TOKEN_BUDGET_CODEX=400000
# AI_SESSIONS_TOKEN_BUDGET_OPENCODE=200000

# --- Telegram channel ---
# Bot token from @BotFather. Required to enable the Telegram channel.
# In BotFather: /setprivacy → Disable, so the bot can read plain-text messages
# in groups (needed for steer-by-default).
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram numeric user ids permitted to bind sessions and
# drive runs. Find your id by DMing @userinfobot. Non-allowed users are
# silently ignored.
TELEGRAM_ALLOWED_USERS=

# --- Speech-to-text (Whisper-compatible) ---
# Voice/audio messages from Telegram are POSTed to <STT_URL>/v1/audio/transcriptions
# and the transcribed text is used as the run prompt.
STT_URL=https://stt.etdofresh.com
# STT_API_KEY=
# STT_MODEL=whisper-1
