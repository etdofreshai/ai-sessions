{
  "name": "ai-sessions",
  "version": "0.1.0",
  "private": true,
  "description": "Thin TypeScript CLI + local HTTP API to call, manage, and view sessions across claude, codex, and opencode.",
  "type": "module",
  "bin": {
    "ai-sessions": "./dist/cli.js",
    "ais": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "dev:serve": "tsx src/cli.ts serve",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.63",
    "commander": "^12.1.0",
    "express": "^5.2.1",
    "fast-glob": "^3.3.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.13",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
